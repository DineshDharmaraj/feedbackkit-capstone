{
  "name": "feedbackkit",
  "version": "1.0.0",
  "description": "Feedback capture + triage — Certified AI-Driven Developer Capstone",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
